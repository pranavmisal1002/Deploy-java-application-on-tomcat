<?xml version="1.0" encoding="UTF-8"?>
<project>

	<modelVersion>4.0.0</modelVersion>
	<groupId>com.devopscicd</groupId>
	<artifactId>DevOps-CICD-war</artifactId>
	<packaging>war</packaging>
	<version>0.1</version>
	<name>DevOps CICD Flow WAR File</name>

	<properties>
		<project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
	</properties>

	<build>
		<pluginManagement>
			<plugins>
				<plugin>
					<artifactId>maven-compiler-plugin</artifactId>
					<configuration>
						<showDeprecation>true</showDeprecation>
						<showWarnings>true</showWarnings>
						<source>1.8</source>
						<target>1.8</target>
					</configuration>
				</plugin>
			</plugins>
		</pluginManagement>
	</build>
<distributionManagement>
    <repository>
        <id>nexus-releases</id>
        <url>http://16.16.124.254:8081/repository/maven-releases/</url>
    </repository>
</distributionManagement>
</project>
